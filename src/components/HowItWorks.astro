---
const steps = [
  {
    icon: '📲',
    num: '01',
    heading: 'Forward your missed calls',
    body: 'Takes 2 minutes. That\'s the setup done.',
  },
  {
    icon: '🎙️',
    num: '02',
    heading: 'It answers and has a real conversation',
    body: 'Grabs the details — name, job, suburb, callback time, all captured.',
  },
  {
    icon: '📋',
    num: '03',
    heading: 'You get an SMS summary',
    body: 'Caller\'s name, job, and number. Your CRM updates automatically. Ready to call them back.',
  },
];
---

<section id="how-it-works" class="bg-near-black py-20 md:py-28">
  <div class="mx-auto max-w-7xl px-5 md:px-8">
    <p class="font-body text-sm font-medium uppercase tracking-[0.2em] text-forest-green">
      Simple as
    </p>
    <h2 class="mt-4 max-w-2xl font-display text-4xl leading-[0.95] tracking-wide text-white sm:text-5xl lg:text-6xl">
      Set Up In Minutes.<br />Runs Itself From There.
    </h2>

    <div class="mt-14 grid gap-10 md:grid-cols-3">
      {
        steps.map((step) => (
          <div class="relative">
            <div class="text-4xl" aria-hidden="true">
              {step.icon}
            </div>
            <div class="mt-4 font-display text-2xl tracking-wide text-deep-teal">
              Step {step.num}
            </div>
            <h3 class="mt-2 font-body text-xl font-semibold text-white">{step.heading}</h3>
            <p class="mt-3 font-body text-base leading-relaxed text-white/60">{step.body}</p>
          </div>
        ))
      }
    </div>

    <p class="mt-14 max-w-2xl font-body text-base leading-relaxed text-white/60">
      No scripts to write. No tech know-how needed. We set up the system for your business —
      you just forward the calls.
    </p>
  </div>
</section>
