---
const STRIPE_URL =
  'https://buy.stripe.com/8x24gAf7seyOgki0Ir3ks00?prefilled_promo_code=FIRSTMONTH80';

const navLinks = [
  { label: 'How It Works', href: '#how-it-works' },
  { label: 'Features', href: '#features' },
  { label: 'Integrations', href: '#integrations' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'FAQ', href: '#faq' },
];
---

<header
  x-data="{ scrolled: false, mobileOpen: false }"
  x-init="window.addEventListener('scroll', () => { scrolled = window.scrollY > 80 })"
  :class="scrolled || mobileOpen ? 'bg-near-black/95 backdrop-blur-sm shadow-lg shadow-black/30' : 'bg-transparent'"
  class="sticky top-0 z-50 w-full transition-colors duration-300"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-5 py-4 md:px-8">
    <!-- Logo -->
    <a href="#top" class="flex items-center gap-3">
      <img
        src="/assets/Tradie_Voice_Mate_Icon.png"
        alt="Tradie Voice Mate"
        class="h-9 w-9"
        width="36"
        height="36"
      />
      <span class="font-body text-base font-semibold text-white">Tradie Voice Mate</span>
    </a>

    <!-- Desktop links -->
    <ul class="hidden items-center gap-8 md:flex">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              class="text-sm font-medium text-white/70 transition-colors hover:text-white"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <!-- Desktop CTA -->
    <a
      href={STRIPE_URL}
      class="hidden rounded-full bg-deep-teal px-5 py-2.5 text-sm font-semibold text-white transition-transform hover:scale-105 md:inline-block"
    >
      Start your trial
    </a>

    <!-- Mobile hamburger -->
    <button
      @click="mobileOpen = !mobileOpen"
      class="flex h-10 w-10 items-center justify-center text-white md:hidden"
      aria-label="Toggle menu"
    >
      <svg x-show="!mobileOpen" class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
      </svg>
      <svg x-show="mobileOpen" x-cloak class="h-7 w-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </nav>

  <!-- Mobile dropdown -->
  <div
    x-show="mobileOpen"
    x-cloak
    x-transition:enter="transition ease-out duration-200"
    x-transition:enter-start="opacity-0 -translate-y-2"
    x-transition:enter-end="opacity-100 translate-y-0"
    class="border-t border-white/10 bg-near-black px-5 pb-6 pt-2 md:hidden"
  >
    <ul class="flex flex-col gap-1">
      {
        navLinks.map((link) => (
          <li>
            <a
              href={link.href}
              @click="mobileOpen = false"
              class="block py-3 text-base font-medium text-white/80 transition-colors hover:text-white"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
    <a
      href={STRIPE_URL}
      class="mt-3 block rounded-full bg-deep-teal px-5 py-3 text-center text-base font-semibold text-white"
    >
      Start your trial
    </a>
  </div>
</header>
