{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "assets/**",
              "components/content/**",
              "components/core/**",
              "components/widget/**",
              "ui_kits/marketing-site/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Staatliches|DM Sans))/i]",
        "message": "Font not provided by the design system. Available: Staatliches, DM Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|href|onClick|disabled|trailingArrow|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, href, onClick, disabled, trailingArrow, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|inverted|inverted-ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'inverted' | 'inverted-ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|elevated|style|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: children, variant, elevated, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:light|dark|pricing)$/]",
        "message": "<Card> variant must be one of 'light' | 'dark' | 'pricing'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|onDark|color|style|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: children, onDark, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureColumn'] > JSXAttribute > JSXIdentifier[name!=/^(?:number|title|children|onDark|divider|style|key|ref|className|style|children)$/]",
        "message": "<FeatureColumn> doesn't accept that prop. Declared props: number, title, children, onDark, divider, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SMSField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|strong|accent|key|ref|className|style|children)$/]",
        "message": "<SMSField> doesn't accept that prop. Declared props: label, value, strong, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='StarRating'] > JSXAttribute > JSXIdentifier[name!=/^(?:rating|size|color|style|key|ref|className|style|children)$/]",
        "message": "<StarRating> doesn't accept that prop. Declared props: rating, size, color, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|icon|style|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: children, variant, icon, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:data|solid|outline|urgent)$/]",
        "message": "<Tag> variant must be one of 'data' | 'solid' | 'outline' | 'urgent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tick'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|onDark|style|key|ref|className|style|children)$/]",
        "message": "<Tick> doesn't accept that prop. Declared props: children, onDark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TranscriptBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:speaker|children|style|key|ref|className|style|children)$/]",
        "message": "<TranscriptBubble> doesn't accept that prop. Declared props: speaker, children, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='TranscriptBubble'] > JSXAttribute[name.name='speaker'] > Literal[value!=/^(?:caller|agent)$/]",
        "message": "<TranscriptBubble> speaker must be one of 'caller' | 'agent'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
